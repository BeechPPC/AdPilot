# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=adpilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
# JWT_SECRET must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_chars

# Admin password hash (bcrypt). Generate with:
#   node -e "require('bcrypt').hash('yourpassword', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=

# Google Ads API Configuration
GOOGLE_ADS_CLIENT_ID=your_client_id
GOOGLE_ADS_CLIENT_SECRET=your_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/oauth2callback

# Anthropic API (for AI Chat)
ANTHROPIC_API_KEY=your_anthropic_api_key

# CORS
CORS_ORIGIN=http://localhost:3000
